# Jan Subagent 3.0.0 - Environment Variables
# Skopiuj ten plik do .env i uzupełnij wartości

# NVIDIA API Key dla modelu Bielik 11B
#
# ⚠️ WAŻNE: Ta metoda jest NIEZALECANA!
#
# Zalecamy użyć automatycznej konfiguracji przez @jan:
# 1. Skonfiguruj MCP (zobacz README.md)
# 2. Rozpocznij konwersację z @jan
# 3. Użyj: setup_api_key z api_key: "twoj-key"
#
# Jeśli mimo to wolisz ręczną konfigurację:
# 1. Uzyskaj API key na: https://build.nvidia.com/
#    - Zaloguj się i przejdź do strony modelu Bielik
#    - Kliknij "Get API Key" w prawym panelu
#    Albo bezpośrednio: https://org.ngc.nvidia.com/setup/api-keys
# 2. Wklej poniżej swój API key
NVIDIA_API_KEY=twoj-nvidia-api-key-tutaj

# Model Bielik ID (zazwyczaj nie trzeba zmieniać)
BIELIK_MODEL_ID=speakleash/bielik-11b-v2.6-instruct

# API Endpoint (zazwyczaj nie trzeba zmieniać)
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1

# Logowanie (debug/production)
LOG_LEVEL=info

# Temperatura domyślna dla korekty (im mniejsza, tym bardziej precyzyjna)
DEFAULT_CORRECTION_TEMPERATURE=0.3

# Maksymalna liczba tokenów
DEFAULT_MAX_TOKENS=4096

# Optional: repo-native policy file
JAN_POLICY_FILE=/absolute/path/to/jan/jan.yml

# Optional: GitHub source context
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPOSITORY=pdurlej/jan-subagent
GITHUB_API_BASE=https://api.github.com

# Optional: Jira source context
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token
